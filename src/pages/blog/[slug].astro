---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogHeader from '../../modules/blog/components/BlogHeader.astro';
import SocialShare from '../../modules/blog/components/SocialShare.astro';
import AuthorCard from '../../modules/blog/components/AuthorCard.astro';
import PostNavigation from '../../modules/blog/components/PostNavigation.astro';
import RelatedPosts from '../../modules/blog/components/RelatedPosts.astro';
import { buildBlogPostPageContext } from '../../modules/blog/services/blogPostPageContext.server';
import {
  getListVisibleBlogPosts,
  getRoutableBlogPosts,
} from '../../modules/blog/services/blogPosts';
import type { CollectionEntry } from 'astro:content';
import readingTime from 'reading-time';

export async function getStaticPaths() {
  const posts = await getRoutableBlogPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description } = post.data;

const { Content } = await post.render();
const readingTimeText = readingTime(post.body).text;
const allPosts = await getListVisibleBlogPosts();
const pageContext = buildBlogPostPageContext({
  post,
  allPosts,
  site: Astro.site ?? Astro.url,
});
---

<BaseLayout
  title={`${title} | Dušan Todorović Blog`}
  description={description}
  image={pageContext.ogImagePath}
  isSearchIndexable={pageContext.isSearchIndexable}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(pageContext.blogPostingJsonLd)}
  />
  {
    pageContext.shouldRenderNoindexMeta && (
      <meta slot="head" name="robots" content="noindex, nofollow" />
    )
  }

  <article class="container content">
    <BlogHeader post={post} readingTime={readingTimeText} />

    <div class="post-content">
      <Content />
    </div>

    <SocialShare url={pageContext.canonicalPostURL} title={title} />

    <AuthorCard />

    <PostNavigation
      prevPost={pageContext.prevPost}
      nextPost={pageContext.nextPost}
    />

    <RelatedPosts
      currentPost={post}
      allPosts={allPosts}
      excludedSlugs={pageContext.relatedPostsExcludedSlugs}
    />

    <footer class="post-footer">
      <a href="/blog">&larr; Back to all posts</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .post-content {
    line-height: var(--line-height-relaxed);
  }

  .post-content :global(h2),
  .post-content :global(h3) {
    font-family: var(--font-family-heading);
    font-weight: var(--font-weight-semibold);
  }

  .post-content :global(h2) {
    font-size: var(--font-size-2xl);
    margin-top: var(--spacing-2xl);
    margin-bottom: var(--spacing-md);
  }

  .post-content :global(h3) {
    font-size: var(--font-size-xl);
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-sm);
  }

  .post-content :global(p) {
    margin-bottom: var(--spacing-md);
  }

  .post-content :global(.code-snippet-title) {
    margin: var(--spacing-sm) 0 var(--spacing-xs);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  .post-content :global(pre) {
    padding: var(--spacing-lg);
    background-color: var(--color-background-alt);
    border-radius: var(--border-radius-lg);
    overflow-x: auto;
    margin-bottom: var(--spacing-md);
  }

  .post-content :global(code) {
    font-family: var(--font-mono);
  }

  .post-content :global(:not(pre) > code) {
    font-size: 0.95em;
    padding: 0.1em 0.35em;
    border-radius: var(--border-radius-sm);
    background-color: var(--color-background-alt);
  }

  .post-content :global(pre code) {
    font-size: var(--font-size-sm);
  }

  .post-content :global(h2 code),
  .post-content :global(h3 code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    font-weight: var(--font-weight-medium);
    color: var(--color-primary-dark);
    padding: 0.08em 0.35em;
    border-radius: var(--border-radius-sm);
    border: 1px solid var(--color-border);
    background-color: var(--color-background-alt);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    padding-left: var(--spacing-lg);
    margin-bottom: var(--spacing-md);
  }

  .post-content :global(li) {
    margin-bottom: var(--spacing-xs);
  }

  .post-content :global(blockquote) {
    padding: var(--spacing-md) var(--spacing-lg);
    border-left: 4px solid var(--color-primary);
    background-color: var(--color-background-alt);
    border-radius: 0 var(--border-radius-md) var(--border-radius-md) 0;
    color: var(--color-text-muted);
    font-style: italic;
    margin: var(--spacing-md) 0;
  }

  .post-content :global(blockquote p) {
    margin: 0;
  }

  .post-content :global(blockquote p + p) {
    margin-top: var(--spacing-sm);
  }

  .post-content :global(table) {
    width: 100%;
    display: block;
    overflow-x: auto;
    border-collapse: separate;
    border-spacing: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-md);
    margin-bottom: var(--spacing-md);
    background-color: var(--color-background);
  }

  .post-content :global(thead th) {
    background-color: var(--color-background-alt);
    color: var(--color-text);
    font-weight: var(--font-weight-semibold);
    font-family: var(--font-family-heading);
    white-space: nowrap;
  }

  .post-content :global(th),
  .post-content :global(td) {
    padding: var(--spacing-sm) var(--spacing-md);
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid var(--color-border);
    min-width: 170px;
  }

  .post-content :global(tbody tr:last-child td) {
    border-bottom: none;
  }

  .post-content :global(tbody tr:nth-child(odd)) {
    background-color: var(--color-background-alt);
  }

  .post-footer {
    margin-top: var(--spacing-2xl);
    padding-top: var(--spacing-xl);
    padding-bottom: var(--spacing-2xl);
    border-top: 1px solid var(--color-border);
  }

  .post-footer a {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    font-weight: var(--font-weight-medium);
    color: var(--color-primary);
    transition: color var(--transition-fast);

    &:hover {
      color: var(--color-primary-hover);
    }

    &:focus-visible {
      outline: 2px solid var(--color-primary);
      outline-offset: 2px;
      border-radius: var(--border-radius-sm);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .post-footer a {
      transition: none;
    }
  }
</style>
